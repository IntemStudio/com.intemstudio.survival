[connection signal="pressed" from="WeaponSelectMenu/MenuOverlay/CenterContainer/VBoxContainer/ContentHBox/ChoicesVBox/ChoiceRow1/TommyGunsButton" to="WeaponSelectMenu" method="_on_tommy_guns_button_pressed"]
[connection signal="pressed" from="WeaponSelectMenu/MenuOverlay/CenterContainer/VBoxContainer/ContentHBox/ChoicesVBox/ChoiceRow2/BoomerangButton" to="WeaponSelectMenu" method="_on_boomerang_button_pressed"]
[connection signal="pressed" from="WeaponSelectMenu/MenuOverlay/CenterContainer/VBoxContainer/ContentHBox/ChoicesVBox/ConcoctionButton" to="WeaponSelectMenu" method="_on_concoction_button_pressed"]
[connection signal="pressed" from="WeaponSelectMenu/MenuOverlay/CenterContainer/VBoxContainer/ContentHBox/ChoicesVBox/RerollButton" to="WeaponSelectMenu" method="_on_reroll_button_pressed"]
[connection signal="pressed" from="WeaponSelectMenu/MenuOverlay/CenterContainer/VBoxContainer/ContentHBox/ChoicesVBox/ChoiceRow0/DiscardSlot0Button" to="WeaponSelectMenu" method="_on_discard_slot_0_pressed"]
[connection signal="pressed" from="WeaponSelectMenu/MenuOverlay/CenterContainer/VBoxContainer/ContentHBox/ChoicesVBox/ChoiceRow1/DiscardSlot1Button" to="WeaponSelectMenu" method="_on_discard_slot_1_pressed"]
[connection signal="pressed" from="WeaponSelectMenu/MenuOverlay/CenterContainer/VBoxContainer/ContentHBox/ChoicesVBox/ChoiceRow2/DiscardSlot2Button" to="WeaponSelectMenu" method="_on_discard_slot_2_pressed"]
[connection signal="timeout" from="Timer" to="." method="_on_timer_timeout"]
[connection signal="health_depleted" from="Player" to="." method="_on_player_health_depleted"]
[connection signal="pressed" from="PauseMenu/MenuOverlay/CenterContainer/PauseMainContent/Buttons/ContinueButton" to="." method="_on_pause_continue_pressed"]
[connection signal="pressed" from="PauseMenu/MenuOverlay/CenterContainer/PauseMainContent/Buttons/SettingsButton" to="PauseMenu" method="_on_settings_button_pressed"]
[connection signal="pressed" from="PauseMenu/MenuOverlay/CenterContainer/PauseMainContent/Buttons/RestartButton" to="." method="_on_pause_restart_pressed"]
[connection signal="pressed" from="PauseMenu/MenuOverlay/CenterContainer/PauseMainContent/Buttons/QuitButton" to="." method="_on_pause_quit_pressed"]
[connection signal="pressed" from="PauseMenu/MenuOverlay/SettingsPanel/SettingsCenter/SettingsVBox/SettingsBackButton" to="PauseMenu" method="_on_settings_back_pressed"]
[connection signal="pressed" from="GameOver/MenuOverlay/CenterContainer/VBoxContainer/Buttons/GameOverRestartButton" to="." method="_on_restart_button_pressed"]
[connection signal="pressed" from="GameOver/MenuOverlay/CenterContainer/VBoxContainer/Buttons/GameOverQuitButton" to="." method="_on_quit_button_pressed"]
